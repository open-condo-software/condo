{
  "name": "template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "prepare": "node ./bin/prepare.js",
    "dev": "yarn build:deps && yarn dev:start",
    "dev:start": "cross-env NODE_ENV=development node --trace-warnings ./../../bin/run-keystone-app.js & yarn types:watch",
    "build:deps": "turbo build --filter=@app/~/^... --filter=!@app/condo",
    "build": "cross-env PHASE=build keystone build",
    "start": "NODE_ENV=production node ./../../bin/run-keystone-app.js",
    "makemigrations": "./../../bin/kmigrator.py makemigrations",
    "migrate": "./../../bin/kmigrator.py migrate",
    "migrate:down": "./../../bin/kmigrator.py down",
    "migrate:unlock": "./../../bin/kmigrator.py unlock",
    "maketypes:local": "mkdirp dist/admin && cross-env DISABLE_STITCH_SCHEMA=true node ./../../bin/create-graphql-schema.js && ./../../node_modules/.bin/graphql-codegen -c codegen.yaml",
    "maketypes:condo": "node ./bin/generate-condo-schema && ./../../node_modules/.bin/graphql-codegen -c condoCodegen.yaml",
    "maketypes": "cross-env NODE_ENV=development yarn maketypes:local && yarn maketypes:condo",
    "createschema": "./../../bin/createschema",
    "createservice": "node ./../../bin/createservice",
    "types:watch": "graphql-codegen -c codegen.ts --watch",
    "worker": "cross-env PHASE=worker DISABLE_NEXT_APP=true node worker.js"
  },
  "dependencies": {
    "@apollo/client": "^3.11.8",
    "~/domains": "link:./domains",
    "@open-condo/bridge": "workspace:^",
    "@open-condo/codegen": "workspace:^",
    "@open-condo/config": "workspace:^",
    "@open-condo/keystone": "workspace:^",
    "@open-condo/miniapp-utils": "workspace:^",
    "@open-condo/next": "workspace:^",
    "@open-condo/ui": "workspace:^",
    "@open-keystone/app-next": "^9.0.3",
    "antd": "^4.24.12",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.10",
    "express": "^4.17.1",
    "graphql": "^16.10.0",
    "lodash": "^4.17.21",
    "next": "^15.5.7",
    "openid-client": "5.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^7.6.0",
    "@graphql-codegen/cli": "^6.2.0",
    "@graphql-codegen/import-types-preset": "^4.0.0",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-codegen/typescript-react-apollo": "^4.4.1",
    "@graphql-tools/graphql-file-loader": "^7.5.17",
    "@graphql-tools/load": "^8.1.0",
    "@open-condo/cli": "workspace:^",
    "@types/react": "^18.3.1",
    "jest": "^29.7.0",
    "jest-jasmine2": "^29.7.0",
    "mkdirp": "^3.0.1",
    "pluralize": "^8.0.0",
    "typescript": "^5.8.3"
  }
}
