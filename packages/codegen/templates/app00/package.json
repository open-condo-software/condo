{
  "name": "@app/{{name}}",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "prepare": "node ./bin/prepare.js",
    "dev": "yarn build:deps && yarn dev:start",
    "dev:start": "node --trace-warnings ./../../bin/run-keystone-app.js",
    "debug": "node inspect node_modules/.bin/keystone dev",
    "build:deps": "turbo build --filter=@app/{{name}}^... --filter=!@app/condo",
    "build": "cross-env PHASE=build keystone build",
    "start": "NODE_ENV=production node ./../../bin/run-keystone-app.js",
    "worker": "cross-env PHASE=worker node worker.js",
    "kmigrator": "python3 ./../../bin/kmigrator.py",
    "makemigrations": "python3 ./../../bin/kmigrator.py makemigrations",
    "migrate": "python3 ./../../bin/kmigrator.py migrate",
    "migrate:down": "python3 ./../../bin/kmigrator.py down",
    "migrate:unlock": "python3 ./../../bin/kmigrator.py unlock",
    "maketypes:{{name}}": "mkdir -p dist/admin && node ./../../bin/create-graphql-schema.js StitchSchemaMiddleware && graphql-codegen -c codegen.yaml",
    "maketypes:condo": "node ./bin/generate-condo-schema.js && graphql-codegen -c condoCodegen.yaml",
    "maketypes": "yarn maketypes:{{name}} && yarn maketypes:condo",
    "createschema": "./../../bin/createschema",
    "createservice": "node ./../../bin/createservice"
  },
  "dependencies": {
    "@apollo/client": "catalog:",
    "@emotion/react": "catalog:",
    "@emotion/styled": "catalog:",
    "@open-keystone/app-next": "catalog:",
    "@open-condo/bridge": "workspace:^",
    "@open-condo/codegen": "workspace:^",
    "@open-condo/config": "workspace:^",
    "@open-condo/keystone": "workspace:^",
    "@open-condo/next": "workspace:^",
    "@open-condo/ui": "workspace:^",
    "@{{name}}/domains": "link:./domains",
    "ajv": "catalog:",
    "antd": "catalog:",
    "classnames": "catalog:",
    "cross-env": "catalog:",
    "dayjs": "catalog:",
    "express": "catalog:",
    "graphql-upload": "catalog:",
    "less": "catalog:",
    "lodash": "catalog:",
    "next": "catalog:",
    "numeral": "2.0.6",
    "rc-queue-anim": "^1.8.5",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-fittext": "^1.0.0",
    "react-markdown": "^4.3.1",
    "react-responsive": "^8.1.0",
    "react-test-renderer": "^16.13.1",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "jest": "catalog:",
    "jest-jasmine2": "catalog:",
    "less-loader": "catalog:",
    "pluralize": "catalog:",
    "typescript": "catalog:",
    "webpack": "catalog:"
  },
  "repository": "https://github.com/open-condo-software/condo/tree/main/apps/{{ name }}"
}
