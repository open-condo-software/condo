{
  "name": "@app/address-service",
  "version": "0.0.0-development",
  "private": true,
  "scripts": {
    "test": "jest",
    "prepare": "node ./bin/prepare.js",
    "dev": "node ./../../bin/run-keystone-app.js",
    "debug": "node inspect node_modules/.bin/keystone dev",
    "build:deps": "turbo build --filter=@app/address-service^...",
    "build": "cross-env PHASE=build keystone build",
    "start": "cross-env NODE_ENV=production node ./../../bin/run-keystone-app.js",
    "kmigrator": "python3 ./../../bin/kmigrator.py",
    "makemigrations": "python3 ./../../bin/kmigrator.py makemigrations",
    "migrate": "python3 ./../../bin/kmigrator.py migrate",
    "migrate:down": "python3 ./../../bin/kmigrator.py down",
    "migrate:unlock": "python3 ./../../bin/kmigrator.py unlock",
    "maketypes": "mkdir -p dist/admin && node ./../../bin/create-graphql-schema.js && ./../../node_modules/.bin/graphql-codegen -c codegen.yaml",
    "createschema": "./../../bin/createschema",
    "createservice": "node ./../../bin/createservice"
  },
  "dependencies": {
    "@address-service/domains": "link:./domains",
    "@apollo/client": "catalog:",
    "@open-condo/cli": "workspace:^",
    "@open-condo/codegen": "workspace:^",
    "@open-condo/config": "workspace:^",
    "@open-condo/icons": "workspace:^",
    "@open-condo/keystone": "workspace:^",
    "@open-condo/miniapp-utils": "workspace:^",
    "@open-condo/ui": "workspace:^",
    "@open-keystone/app-admin-ui": "catalog:",
    "express": "catalog:",
    "fast-xml-parser": "^5.4.0",
    "graphql": "catalog:",
    "graphql-tag": "catalog:",
    "lodash": "catalog:",
    "openid-client": "catalog:",
    "react": "catalog:",
    "react-router-dom": "5.2.0",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "cross-env": "catalog:",
    "jest": "catalog:",
    "jest-jasmine2": "catalog:",
    "typescript": "catalog:"
  }
}
